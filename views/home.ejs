<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Campus Map</title>

  <!-- Google Fonts (same as frontend) -->
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&family=Playfair+Display&display=swap" rel="stylesheet">

  <!-- CSS -->
  <link rel="stylesheet" href="/home.css">

  <!-- Favicon -->
  <link rel="icon" type="image/jpg" href="/logo.jpg">
</head>

<body>

<!-- ================= HEADER ================= -->
<header class="topbar">
  <div class="topbar-brand">Campus Map Navigation</div>
</header>

<!-- ================= INFO PANEL ================= -->
<div class="container">

  <div id="infoPanel" class="info-card">
    <p id="distanceLeft">📍 Remaining: 0 meters</p>
    <p id="status">⏳ Status: Waiting...</p>
  </div>

</div>

<!-- ================= MAP ================= -->
<div id="map"></div>

<!-- ================= FOOTER ================= -->
<footer class="footer">
  <p>© 2026 CampusAI — Smart Campus Navigation 🌿</p>
</footer>

<!-- ================= SCRIPTS ================= -->

<!-- Your logic -->
<script src="/script.js"></script>

<!-- Google Maps -->
<script>
    fetch('/config')
        .then(res => res.json())
        .then(config => {
            const script = document.createElement('script');
            script.src = `https://maps.googleapis.com/maps/api/js?key=${config.googleMapsApiKey}&libraries=geometry&callback=initMap`;
            script.async = true;
            script.defer = true;
            document.head.appendChild(script);
        });
</script>
</body>
</html>