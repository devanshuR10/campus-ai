<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Events</title>
    <link rel="stylesheet" href="/events.css">
</head>
<body>

<!-- HEADER -->
<header class="topbar">
    <div class="topbar-brand">Campus AI — Events</div>
</header>

<!-- INFO PANEL -->
<div class="container">
    <div class="info-card" id="eventDetails">
        <p>Click a building marker to view events</p>
    </div>

    <div id="navBtnContainer" style="display:none; margin-top: 10px;">
        <button id="navigateBtn" onclick="navigateToPlace()">🧭 Navigate to this place</button>
    </div>

    <button id="addEventBtn">+ Add Event</button>
</div>

<!-- MAP -->
<div id="map"></div>

<!-- FOOTER -->
<footer class="footer">
    <p>© 2026 Campus AI</p>
</footer>

<script>
  const events = <%- JSON.stringify(events) %>;
</script>
<script src="/events.js"></script>
<script src="https://maps.googleapis.com/maps/api/js?key=AIzaSyD8Yj1KnZlqcjdzgqElraLaktAaYyjRlqY&libraries=geometry&callback=initMap" async defer></script>
</body>
</html>